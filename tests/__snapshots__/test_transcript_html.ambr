  .highlight {
    margin: 0.5rem 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow-x: auto;
    background: var(--code-bg) !important;
  }
  .highlight pre {
    margin: 0;
    padding: 0.75rem 0.85rem;
