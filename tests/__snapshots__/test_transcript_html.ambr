    border-radius: 8px;
    overflow-x: auto;
    background: var(--code-bg) !important;
  }
  .highlight pre {
    margin: 0;
    padding: 0.75rem 0.85rem;
    background: transparent !important;
    border: none;
    border-radius: 0;
