  <body>
  <div class="wrap"><header><h1>jutul-agent transcript</h1><div class="badges"><span class="badge">Tools: 2</span></div></header><div class="controls"><fieldset><legend>Filter</legend><label><input type="checkbox" class="kind-filter" data-filter="tools" checked> Tools</label></fieldset><button type="button" id="collapse-all">Collapse all</button><button type="button" id="expand-all">Expand all</button></div><div class="timeline"><article class="event" data-kind="tool_call" data-filter="tools"><div class="event-header"><span class="event-kind tool">Tool · julia_eval</span><time datetime="2026-05-19T10:00:01+00:00">2026-05-19T10:00:01+00:00</time></div><h3>julia_eval</h3><p><em>(no args)</em></p></article><article class="event" data-kind="tool_result" data-filter="tools"><div class="event-header"><span class="event-kind tool">Tool result · julia_eval</span><time datetime="2026-05-19T10:00:02+00:00">2026-05-19T10:00:02+00:00</time></div><h3>julia_eval</h3><div class="highlight"><pre><span></span><code><span class="mi">4</span>
  </code></pre></div>
  </article></div><p class="share-note">To share this transcript, distribute the session folder (<code>transcript.html</code> plus any <code>artifacts/</code>) or run <code>jutul-agent transcript --bundle</code> to create a zip.</p></div>
  <script>
  (function () {
    const events = document.querySelectorAll(".event[data-filter]");
    const checkboxes = document.querySelectorAll(".kind-filter");
    function applyFilters() {
      const hidden = new Set(
        [...checkboxes].filter((cb) => !cb.checked).map((cb) => cb.dataset.filter)
      );
      events.forEach((el) => {
        el.style.display = hidden.has(el.dataset.filter) ? "none" : "";
      });
    }
    checkboxes.forEach((cb) => cb.addEventListener("change", applyFilters));
    document.getElementById("collapse-all")?.addEventListener("click", () => {
      document.querySelectorAll("details").forEach((d) => { d.open = false; });
    });
    document.getElementById("expand-all")?.addEventListener("click", () => {
      document.querySelectorAll("details").forEach((d) => { d.open = true; });
    });
  })();
  </script>
  </body>
  </html>
  
  '''
