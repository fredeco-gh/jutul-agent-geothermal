# Copy this file to `.env` and fill in at least one provider API key.
#
#   cp .env.example .env          # Unix / Git Bash
#   Copy-Item .env.example .env   # PowerShell
#
# jutul-agent loads `.env` from the repo root on startup (CLI and pytest).

# Default model is openai:gpt-5.4-mini — set OPENAI_API_KEY if you use it.
OPENAI_API_KEY=

# Or use Anthropic instead (uncomment and set JUTUL_AGENT_MODEL below).
ANTHROPIC_API_KEY=

# Optional: override the default model (provider:model).
# JUTUL_AGENT_MODEL=anthropic:claude-sonnet-4-6

# Optional: model for live LLM tests in tests/live/ (defaults to openai:gpt-5.4-mini).
# JUTUL_AGENT_LIVE_MODEL=anthropic:claude-sonnet-4-6
