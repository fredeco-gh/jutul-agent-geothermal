# Copy this file to `.env` and fill in at least one provider API key.
#
#   cp .env.example .env          # Unix / Git Bash
#   Copy-Item .env.example .env   # PowerShell
#
# You don't have to edit this file: jutul-agent prompts for a key when a model
# needs one and saves it for future runs. Pick and switch models with `/model`
# in the app. Set whichever provider key(s) you'll use.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local models via Ollama (https://ollama.com) need no key — just run `ollama serve`.

# Dev/CI override for the model jutul-agent uses (provider:model). Most users
# should pick a model with `/model` in the app instead of setting this.
# JUTUL_AGENT_MODEL=anthropic:claude-sonnet-4-6

# Model for the live LLM tests in tests/live/.
# JUTUL_AGENT_LIVE_MODEL=anthropic:claude-sonnet-4-6
