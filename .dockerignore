# Allowlist: the image needs the project metadata and the package source,
# nothing else from the checkout enters the build context.
*
!pyproject.toml
!uv.lock
!README.md
!LICENSE
!src

# Local artifacts inside src that the image must not inherit.
src/**/__pycache__
src/jutul_agent/**/Manifest.toml
src/jutul_agent/simulators/*/julia_env/JutulAgent/
